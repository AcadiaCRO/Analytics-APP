# Runtime environment: development | staging | production
NODE_ENV=development

# Server startup mode: single | both
# For PM2 with two separate processes keep this as single.
RUN_MODE=single

# Default app port (development/production)
PORT=8647

# Dedicated port for staging mode
STAGING_PORT=8648

# Base URL used in startup logs
BASE_URL=http://localhost

# CORS allowed origins (comma-separated)
CORS_ORIGIN=*

# Staging log file location
STAGING_LOG_FILE_PATH=./logs/staging.log

# Keep staging logs for N days (default 1)
STAGING_LOG_RETENTION_DAYS=1

# Ignore these paths in staging error logs (comma-separated)
STAGING_IGNORED_ERROR_PATHS=/favicon.ico

# Redis connection URL (optional - defaults to localhost)
REDIS_URL=

# Cache TTL for Redis values in seconds
CACHE_TTL_SECONDS=86400

# Google Analytics service account (ALL fields loaded from env)
GA_TYPE=service_account
GA_PROJECT_ID=social-proof-451315
GA_PRIVATE_KEY_ID=380ffb27f52c021c4056f54af6910a2f581c2568
# Keep newline escaped as \n if one-line env value
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GA_CLIENT_EMAIL=ga4-analytics-proxy@social-proof-451315.iam.gserviceaccount.com
GA_CLIENT_ID=
GA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GA_TOKEN_URI=https://oauth2.googleapis.com/token
GA_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GA_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/ga4-analytics-proxy%40social-proof-451315.iam.gserviceaccount.com
GA_UNIVERSE_DOMAIN=googleapis.com
